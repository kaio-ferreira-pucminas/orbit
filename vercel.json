{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "outputDirectory": "src",
  "trailingSlash": false,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/pages/index.html" }
  ],
  "redirects": [
    { "source": "/feed",            "destination": "/pages/feed.html",            "permanent": false },
    { "source": "/auth",            "destination": "/pages/auth.html",            "permanent": false },
    { "source": "/profile",         "destination": "/pages/profile.html",         "permanent": false },
    { "source": "/forgot-password", "destination": "/pages/forgot-password.html", "permanent": false },
    { "source": "/reset-password",  "destination": "/pages/reset-password.html",  "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
