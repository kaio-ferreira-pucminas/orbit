# =================================================================
# CONFIGURAÇÃO DE EMAIL — Resend
# =================================================================
# 1. Crie uma conta gratuita em https://resend.com
# 2. Configure um domínio próprio (ou use o sandbox para testes)
# 3. Gere uma API key em https://resend.com/api-keys
# 4. Copie este arquivo como .env e preencha os valores abaixo

RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@seudominio.com
RESEND_FROM_NAME=Orbit

# =================================================================
# URL pública do frontend (usada nos links dos emails)
# =================================================================
APP_URL=http://localhost:3000
