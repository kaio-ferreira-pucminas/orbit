{
  "cleanUrls": true,
  "trailingSlash": false,
  "errorPage": "404.html",
  "rewrites": [
    { "source": "/", "destination": "/pages/index.html" }
  ],
  "redirects": [
    { "source": "/feed",            "destination": "/pages/feed.html" },
    { "source": "/auth",            "destination": "/pages/auth.html" },
    { "source": "/profile",         "destination": "/pages/profile.html" },
    { "source": "/forgot-password", "destination": "/pages/forgot-password.html" },
    { "source": "/reset-password",  "destination": "/pages/reset-password.html" },
    { "source": "/dashboard",       "destination": "/pages/dashboard.html" },
    { "source": "/mensagens",       "destination": "/pages/mensagens.html" },
    { "source": "/agenda",          "destination": "/pages/agenda.html" },
    { "source": "/entrevistas",     "destination": "/pages/entrevistas.html" },
    { "source": "/empresa",         "destination": "/pages/empresa-dashboard.html" },
    { "source": "/vagas",           "destination": "/pages/vagas.html" },
    { "source": "/talentos",        "destination": "/pages/empresa-talentos.html" },
    { "source": "/vaga",            "destination": "/pages/vaga-detalhes.html" },
    { "source": "/completar-perfil","destination": "/pages/completar-perfil.html" },
    { "source": "/meus-projetos",   "destination": "/pages/meus-projetos.html" },
    { "source": "/perfil-publico",  "destination": "/pages/perfil-publico.html" },
    { "source": "/oportunidades",   "destination": "/pages/oportunidades.html" },
    { "source": "/candidatos",      "destination": "/pages/empresa-candidatos.html" },
    { "source": "/minhas-vagas",    "destination": "/pages/empresa-vagas.html" },
    { "source": "/nova-vaga",       "destination": "/pages/empresa-nova-vaga.html" },
    { "source": "/busca",           "destination": "/pages/busca.html" },
    { "source": "/empresa-perfil",  "destination": "/pages/empresa-perfil.html" },
    { "source": "/completar-perfil-empresa", "destination": "/pages/completar-perfil-empresa.html" }
  ]
}
